# 前端环境变量 (Vite)
# 所有 VITE_ 前缀的变量在构建时会注入到 import.meta.env

# ============== Sentry 错误追踪 (V1.30.3 P2-8, 可选) ==============
# 留空则禁用
# VITE_SENTRY_DSN=https://xxxxx@xxxxx.ingest.sentry.io/12345
# VITE_SENTRY_ENABLED=true
# VITE_SENTRY_ENVIRONMENT=production
# VITE_SENTRY_TRACES_SAMPLE_RATE=0.05
# VITE_SENTRY_REPLAYS_SESSION_RATE=0.1
# VITE_APP_VERSION=1.30.3
