{
  "name": "avm-frontend",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "lint": "node scripts/check-missing-imports.cjs",
    "lint:fix": "node scripts/check-missing-imports.cjs --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "format": "npx prettier@3 --write \"src/**/*.{ts,tsx,json}\"",
    "format:check": "npx prettier@3 --check \"src/**/*.{ts,tsx,json}\""
  },
  "dependencies": {
    "@ant-design/icons": "^5.5.2",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@sentry/react": "^10.67.0",
    "@types/dompurify": "^3.0.5",
    "@xyflow/react": "^12.11.2",
    "antd": "^5.22.5",
    "antd-style": "^3.7.1",
    "axios": "^1.7.9",
    "dayjs": "^1.11.13",
    "dompurify": "^3.4.12",
    "echarts": "^6.1.0",
    "echarts-for-react": "^3.0.6",
    "marked": "^18.0.7",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^7.0.0",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitejs/plugin-react-swc": "^4.3.1",
    "@vitest/coverage-v8": "^4.1.10",
    "jsdom": "^29.1.1",
    "typescript": "^5.7.2",
    "vite": "^5.4.11",
    "vitest": "^4.1.10"
  }
}
