# 后端环境变量 (V1.30)

# ============== 服务 ==============
PORT=4000
NODE_ENV=development                 # development | production

# ============== 数据库 ==============
# 开发: SQLite (默认)
DATABASE_URL="file:./data.db"
# 生产: PostgreSQL (推荐)
# DATABASE_URL="postgresql://avm:password@postgres:5432/avm?schema=public"
# 切换: 跑 npm run db:push:pg  (会自动替换 schema.prisma)

# ============== 安全 (V1.30) ==============
# bcrypt cost (4-12, 默认 10 推荐)
BCRYPT_ROUNDS=10
# Token 过期时间 (小时, 默认 168 = 7 天)
TOKEN_TTL_HOURS=168

# ============== 限流 ==============
# 全局限流窗口 (毫秒, 默认 60000 = 1 分钟)
RATE_LIMIT_WINDOW_MS=60000
# 每窗口最大请求数 (默认 300)
RATE_LIMIT_MAX=300

# ============== 日志 ==============
# winston 日志级别: error | warn | info | http | debug
LOG_LEVEL=info

# ============== LLM (可选) ==============
# 进系统后到 /llm-settings 配置更方便, 这里仅作为后备
# LLM_PROVIDER=openai
# LLM_API_KEY=sk-xxx
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-4o-mini

# ============== Seed 演示账号密码 (V1.30.2 P3-1d) ==============
# 启动 seed 时创建 admin/pm/普通用户 的密码, 必须满足强密码策略
# (>= 8 位 + 数字 + 字母, 不在黑名单, 不与 username 相同)
# ⚠️ 生产环境 NODE_ENV=production 下，使用下方默认演示密码会直接导致 seed 失败
#    请改为高强度随机密码，且不要提交到代码仓库
SEED_ADMIN_PASSWORD=Admin@2026
SEED_PM_PASSWORD=Pm@2026
SEED_USER_PASSWORD=User@2026

# V1.30.3 P0: CORS 白名单 (生产环境必须配置, 逗号分隔)
# ⚠️ 未配置时开发模式允许任意 origin，但生产环境 NODE_ENV=production 下启动会报错
CORS_ORIGIN=https://your-domain.com

# V1.30.3 P0: 敏感字段加密 (生产环境必须, 32 字节 base64)
# ⚠️ NODE_ENV=production 时未配置或长度错误，服务将拒绝启动
# 生成: npx tsx -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
API_KEY_ENCRYPTION_KEY=

# ============== Sentry 错误追踪 (V1.30.3 P2-8, 可选) ==============
# 配置 DSN 后自动启用，留空则禁用
# 获取 DSN: https://sentry.io → Project → Settings → Client Keys (DSN)
# SENTRY_DSN=https://xxxxx@xxxxx.ingest.sentry.io/12345
# SENTRY_ENABLED=true
# SENTRY_ENVIRONMENT=production
# SENTRY_TRACES_SAMPLE_RATE=0.05
