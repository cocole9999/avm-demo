# AVM 项目中心 - 根目录环境变量 (V1.30 生产化)

# ============== 生产部署必须修改 ==============
# Postgres 密码 (Docker Compose 用)
POSTGRES_PASSWORD=avm_secure_pwd_change_me

# CORS 允许的来源 (多个用逗号分隔, 生产必改)
CORS_ORIGIN=http://your-domain.com,https://your-domain.com

# 备份保留天数
BACKUP_KEEP_DAYS=7

# Token 过期时间 (小时)
TOKEN_TTL_HOURS=168

# bcrypt cost
BCRYPT_ROUNDS=10

# 限流
RATE_LIMIT_MAX=300
RATE_LIMIT_WINDOW_MS=60000

# 日志级别
LOG_LEVEL=info

# ============== 加密与安全 (生产必改) ==============
# API Key 加密密钥 (32 字节 base64, 用于 AES-256-GCM 加密 LLM/SSO 凭证)
API_KEY_ENCRYPTION_KEY=
# Sentry DSN (错误追踪, 留空则不启用)
SENTRY_DSN=
# CSRF 保护 (仅 Cookie 认证场景启用, JWT Bearer 无需)
ENABLE_CSRF_PROTECTION=false

# ============== 数据库性能 (V1.46) ==============
# Prisma 连接池大小 (生产默认 10, 开发默认 5)
PRISMA_CONNECTION_LIMIT=10
# 慢查询阈值 (毫秒, 生产默认 500, 开发默认 100)
SLOW_QUERY_MS=500

# ============== 监控栈 (可选) ==============
# Grafana 管理员账号 (见 monitoring/docker-compose.monitoring.yml)
GRAFANA_USER=admin
GRAFANA_PASSWORD=
