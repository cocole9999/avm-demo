# AVM 项目中心 - 根目录环境变量 (V1.30 生产化)

# ============== 生产部署必须修改 ==============
# Postgres 密码 (Docker Compose 用)
POSTGRES_PASSWORD=avm_secure_pwd_change_me

# CORS 允许的来源 (多个用逗号分隔, 生产必改)
CORS_ORIGIN=http://your-domain.com,https://your-domain.com

# 备份保留天数
BACKUP_KEEP_DAYS=7

# Token 过期时间 (小时)
TOKEN_TTL_HOURS=168

# bcrypt cost
BCRYPT_ROUNDS=10

# 限流
RATE_LIMIT_MAX=300
RATE_LIMIT_WINDOW_MS=60000

# 日志级别
LOG_LEVEL=info
